# Appwrite Configuration
# Get these from your Appwrite project dashboard: Settings > Keys
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=nursearena

# Server-only env vars (not exposed to client)
APPWRITE_API_KEY=your_server_api_key
APPWRITE_DATABASE_ID=nursearena

# Setup Instructions:
# 1. Create an Appwrite project and get the endpoint + project ID
# 2. Create the database and collections defined in the schema
# 3. Generate an API key with full access
# 4. Start the app: npm run dev
